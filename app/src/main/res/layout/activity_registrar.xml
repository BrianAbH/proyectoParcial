<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/activity_registrar"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- HEADER -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/header"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:background="@color/primary_dark"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageButton
                android:id="@+id/ivVolver"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="12dp"
                android:background="@null"
                android:contentDescription="@string/ic_back"
                android:padding="10dp"
                android:src="@drawable/ic_back"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvTitulo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/registrar_elementos"
                android:textColor="@color/bg_card"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/ivVolver"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- CONTENEDOR DEL FORMULARIO -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_margin="20dp"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/header"
            app:layout_constraintVertical_bias="0.0">

            <!-- TITULOS -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/titulo_formulario"
                android:textSize="30sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/subtitulo_formulario"
                android:textColor="@color/text_muted"
                android:textSize="15sp" />

            <!-- NOMBRE -->
            <TextView
                style="@style/FormLabel"
                android:text="@string/label_nombre" />

            <EditText
                android:id="@+id/etNombre"
                style="@style/FormInput"
                android:hint="@string/hint_nombre"
                android:inputType="textPersonName" />

            <!-- CATEGORIA -->
            <TextView
                style="@style/FormLabel"
                android:text="@string/label_categoria" />

            <Spinner
                android:id="@+id/spCategoria"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:background="@drawable/bg_edittext"
                android:paddingHorizontal="16dp" />

            <!-- CANTIDAD -->
            <TextView
                style="@style/FormLabel"
                android:text="@string/label_cantidad" />

            <EditText
                android:id="@+id/etCantidad"
                style="@style/FormInput"
                android:hint="@string/hint_cantidad"
                android:inputType="number" />

            <!-- UBICACION -->
            <TextView
                style="@style/FormLabel"
                android:text="@string/label_ubicacion" />

            <EditText
                android:id="@+id/etUbicacion"
                style="@style/FormInput"
                android:hint="@string/hint_ubicacion"
                android:inputType="text" />

            <!-- OBSERVACION -->
            <TextView
                style="@style/FormLabel"
                android:text="@string/label_observacion" />

            <EditText
                android:id="@+id/etObservacion"
                style="@style/FormInput"
                android:hint="@string/hint_observacion"
                android:inputType="textMultiLine" />

            <!-- FECHA -->
            <TextView
                style="@style/FormLabel"
                android:text="@string/label_fecha" />

            <DatePicker
                android:id="@+id/dpFecha"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:calendarViewShown="false"
                android:datePickerMode="spinner" />

            <!-- BOTON GUARDAR -->
            <Button
                android:id="@+id/btnGuardar"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="24dp"
                android:backgroundTint="@color/bg_button_guardar"
                android:text="@string/titulo_boton_guardar"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textStyle="bold" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>